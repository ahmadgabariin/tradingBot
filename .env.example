# Binance API Keys (get from binance.com > API Management)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# Testnet (set to true for paper trading on Binance testnet)
USE_TESTNET=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Claude AI (for signal analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Bot Settings
BOT_MODE=paper               # paper | limited | full
BOT_BUDGET=100               # USD amount bot is allowed to use
MAX_TRADE_PERCENT=10         # Max % of budget per trade (10 = $10 per trade)
STOP_LOSS_PERCENT=2          # Stop loss %
TAKE_PROFIT_PERCENT=4        # Take profit %
TRADING_PAIRS=BTC/USDT,ETH/USDT,BNB/USDT

# Dashboard
DASHBOARD_PORT=8000
DASHBOARD_HOST=0.0.0.0
